# 复制本文件为 .env 后填值。.env 已被 .gitignore 排除，禁止提交。

# ---- 飞书企业自建应用 ----
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxxxxxx

# ---- LLM ----
# 主力模型（Anthropic）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-6
ANTHROPIC_MODEL_JUDGE=claude-haiku-4-5-20251001

# Coze 工作流内调用 DeepSeek-V3（脚本生成）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# ---- Runtime flags ----
# 飞书写入默认 dry-run，需显式设为 false 才真写
FEISHU_COMMIT=false
